// Отправка уведомления о смене статуса проекта
app.post('/api/notifications/project-status', async (req, res) => {
  const { userId, projectId, projectTitle, status } = req.body;
  
  if (!userId || !projectId || !projectTitle || !status) {
    return res.status(400).json({ success: false, error: 'Отсутствуют обязательные параметры' });
  }
  
  console.log(`Отправка уведомления о смене статуса проекта для ${userId}: "${projectTitle}" (${status})`);
  const result = await notificationService.notifyProjectStatusChange(userId, projectId, projectTitle, status);
  res.json({ success: result });
});

