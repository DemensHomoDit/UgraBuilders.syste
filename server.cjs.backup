  console.log('- /api/admin/sync-bitrix - синхронизация лидов из Bitrix24 (для админов/менеджеров)');
  console.log('- /api/admin/sync-status - получение статуса синхронизации (для админов/менеджеров)');
  console.log('- /api/admin/convert-leads-to-forms - конвертация лидов из Bitrix24 в заявки с форм (для админов/менеджеров)');
  console.log('- /api/forms/:id/status - обновление статуса заявки (для админов/менеджеров)');
  console.log('- /api/forms/:id/pin - закрепление/открепление заявки (для админов/менеджеров)');
  console.log('- /api/admin/setup-forms-tables - настройка таблиц форм (для админов)');
  
  // Запускаем автоматическую синхронизацию по расписанию
  console.log(`⏰ Запланирована автоматическая синхронизация с Bitrix24 по расписанию: ${SYNC_SCHEDULE}`);
  cron.schedule(SYNC_SCHEDULE, async () => {
    console.log('🔄 Запуск запланированной синхронизации с Bitrix24');
    try {
      await syncBitrixDataWithRetry();
    } catch (error) {
      console.error('❌ Ошибка при выполнении запланированной синхронизации:', error);
    }
  });
  
  // Запускаем первичную синхронизацию через 10 секунд после старта сервера
  console.log('⏱️ Запланирована первичная синхронизация через 10 секунд после запуска');
  setTimeout(async () => {
    try {
      console.log('🔄 Запуск первичной синхронизации с Bitrix24');
      await syncBitrixDataWithRetry();
    } catch (error) {
      console.error('❌ Ошибка при выполнении первичной синхронизации:', error);
    }
  }, 10000);
}); 